    pin (I) { direction : input; capacitance : 0.001; }
    pin (IB) { direction : input; capacitance : 0.001; }
    pin (O) { direction : output;
      timing () {
        related_pin : "I";
        cell_rise (scalar) { values ("0.0500"); }
        cell_fall (scalar) { values ("0.0500"); }
        rise_transition (scalar) { values ("0.010"); }
        fall_transition (scalar) { values ("0.010"); }
      }
    }
  }
}
