# Build artefacts produced by the top-level Makefile.
build/
deps/.initialised

# Per-tool build dirs (each cloned dep has its own gitignore but we
# don't want anything inadvertently committed at the wrapper level).
deps/*/build/
deps/*/_build/
deps/*/env/

# Demo intermediates (.bit is the only thing worth carrying out,
# everything else is rebuildable from sources).
johnson/top.json
johnson/top.edif
johnson/counter28.fasm
johnson/counter28.frames
johnson/counter28.bit

# Editor / OS noise.
*.swp
*~
.DS_Store

# Per-experiment build scratch (Vivado / xsim / Python) and rebuildable
# FPGA artefacts.  The HDL/asm/scripts are the sources; bit/fasm/frames/edif
# regenerate from them.
.Xil/
.hbs/
.cache/
xsim.dir/
__pycache__/
*.pyc
*.jou
*.log
*.pb
*.wdb
*.str
*.backup.log
*.backup.jou
parser_stderr.log
*.report
*.bit
*.fasm
*.frames
*.edif
top.json

# Claude Code local runtime state.
.claude/

# Calculator (uartram) yosys-slang flow intermediates (.bit is rebuildable).
uartram/uartram_calc.json
uartram/uartram_calc.fasm
uartram/uartram_calc.frames
uartram/uartram_calc.bit

# SVS-native synthesis work moved to jrrk2/System-Verilog-suite (separate repo).
deps/System-Verilog-suite/
